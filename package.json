{
  "name": "@vitabletech/meta-sdk",
  "version": "1.0.2",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "lint:fix": "eslint --fix . --ext .js,.ts",
    "prepare": "husky",
    "docs:dev": "cd docs && npm run docs:dev",
    "docs:build": "cd docs && npm run docs:build"
  },
  "description": "A highly scalable, modern, and generic Node.js SDK for interacting with the Meta Graph API (Facebook and Instagram).",
  "keywords": [
    "meta",
    "facebook",
    "instagram",
    "graph-api",
    "sdk",
    "api",
    "vitabletech",
    "meta-sdk",
    "facebook-sdk",
    "instagram-sdk",
    "graph-sdk",
    "node-sdk",
    "js-sdk",
    "ts-sdk"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/vitabletech/Meta-SDK#readme",
  "bugs": {
    "url": "https://github.com/vitabletech/Meta-SDK/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vitabletech/Meta-SDK.git"
  },
  "author": {
    "name": "Mayank Singh Kushwah",
    "url": "https://vitabletech.in"
  },
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.3",
    "@eslint/eslintrc": "^2.1.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^8.57.1",
    "eslint-plugin-node": "^11.1.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.4",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vue": "^3.5.39"
  }
}
